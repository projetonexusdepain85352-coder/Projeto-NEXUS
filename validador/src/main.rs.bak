use postgres::Client;
use postgres::NoTls;
use std::io::{self, BufRead, Write};

struct Documento {
    id: String,
    source: String,
    domain: String,
    doc_type: String,
    content_length: i32,
    preview: String,
}

fn buscar_pendentes(client: &mut Client) -> Vec<Documento> {
    let rows = client.query(
        "SELECT d.id::text, d.source, d.domain, d.doc_type, d.content_length,
                LEFT(convert_from(convert_to(d.content, 'UTF8'), 'UTF8'), 800) as preview
         FROM documents d
         JOIN validation v ON v.document_id = d.id
         WHERE v.status = 'pending'
         ORDER BY d.domain, d.collected_at
         LIMIT 50",
        &[],
    ).expect("Erro ao buscar documentos");

    rows.iter().map(|row| Documento {
        id: row.get(0),
        source: row.get(1),
        domain: row.get(2),
        doc_type: row.get(3),
        content_length: row.get(4),
        preview: row.get(5),
    }).collect()
}

fn aprovar(client: &mut Client, id: &str) {
    client.execute(
        "UPDATE validation SET status = 'approved', decided_by = 'human', decided_at = NOW()
         WHERE document_id::text = $1",
        &[&id],
    ).expect("Erro ao aprovar");
}

fn rejeitar(client: &mut Client, id: &str, motivo: &str) {
    client.execute(
        "UPDATE validation SET status = 'rejected', rejection_reason = $2,
         decided_by = 'human', decided_at = NOW()
         WHERE document_id::text = $1",
        &[&id, &motivo],
    ).expect("Erro ao rejeitar");
}

fn limpar_tela() {
    print!("\x1B[2J\x1B[1;1H");
    io::stdout().flush().unwrap();
}

fn main() {
    let senha = std::env::var("KB_INGEST_PASSWORD").unwrap_or_else(|_| {
        eprintln!("[ERRO] KB_INGEST_PASSWORD não definida.");
        std::process::exit(1);
    });

    let conn_str = format!(
        "host=localhost port=5432 dbname=knowledge_base user=kb_ingest password={}",
        senha
    );

    let mut client = Client::connect(&conn_str, NoTls).unwrap_or_else(|e| {
        eprintln!("[ERRO] Falha ao conectar: {}", e);
        std::process::exit(1);
    });

    let stdin = io::stdin();
    let mut aprovados = 0;
    let mut rejeitados = 0;
    let mut pulados = 0;

    loop {
        let docs = buscar_pendentes(&mut client);

        if docs.is_empty() {
            limpar_tela();
            println!("╔══════════════════════════════════════╗");
            println!("║     VALIDAÇÃO CONCLUÍDA              ║");
            println!("╚══════════════════════════════════════╝");
            println!();
            println!("  Aprovados : {}", aprovados);
            println!("  Rejeitados: {}", rejeitados);
            println!("  Pulados   : {}", pulados);
            println!();
            println!("Nenhum documento pendente restante.");
            break;
        }

        for doc in &docs {
            limpar_tela();

            println!("╔══════════════════════════════════════════════════════════════╗");
            println!("║  NEXUS — VALIDADOR DE DOCUMENTOS                            ║");
            println!("╚══════════════════════════════════════════════════════════════╝");
            println!();
            println!("  Domínio  : {}", doc.domain);
            println!("  Tipo     : {}", doc.doc_type);
            println!("  Tamanho  : {} bytes", doc.content_length);
            println!("  Fonte    : {}", doc.source);
            println!();
            println!("──────────────────────────────────────────────────────────────");
            println!("  PRÉVIA DO CONTEÚDO:");
            println!("──────────────────────────────────────────────────────────────");
            println!();

            for linha in doc.preview.lines().take(30) {
                println!("  {}", linha);
            }

            println!();
            println!("──────────────────────────────────────────────────────────────");
            println!("  Sessão: aprovados={} rejeitados={} pulados={}", aprovados, rejeitados, pulados);
            println!("──────────────────────────────────────────────────────────────");
            println!();
            println!("  [a] Aprovar    [r] Rejeitar    [p] Pular    [q] Sair");
            println!();
            print!("  Decisão: ");
            io::stdout().flush().unwrap();

            let mut linha = String::new();
            stdin.lock().read_line(&mut linha).unwrap();
            let decisao = linha.trim().to_lowercase();

            match decisao.as_str() {
                "a" => {
                    aprovar(&mut client, &doc.id);
                    aprovados += 1;
                }
                "r" => {
                    print!("  Motivo da rejeição: ");
                    io::stdout().flush().unwrap();
                    let mut motivo = String::new();
                    stdin.lock().read_line(&mut motivo).unwrap();
                    let motivo = motivo.trim().to_string();
                    let motivo = if motivo.is_empty() {
                        "sem motivo especificado".to_string()
                    } else {
                        motivo
                    };
                    rejeitar(&mut client, &doc.id, &motivo);
                    rejeitados += 1;
                }
                "p" => {
                    pulados += 1;
                }
                "q" => {
                    limpar_tela();
                    println!("Sessão encerrada.");
                    println!("Aprovados={} Rejeitados={} Pulados={}", aprovados, rejeitados, pulados);
                    return;
                }
                _ => {
                    pulados += 1;
                }
            }
        }
    }
}
