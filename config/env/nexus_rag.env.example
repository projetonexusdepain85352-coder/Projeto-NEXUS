# Obrigatorio
RUST_LOG=info
NEXUS_OLLAMA_URL=http://localhost:11434
NEXUS_BASE_MODEL=mistral
# QDRANT_URL usa porta 6336 (gRPC), NAO 6335 (REST)
QDRANT_URL=http://localhost:6336
# POSTGRES_HOST e o IP do gateway WSL, nao localhost
# Descobrir com: ip route | grep default | awk "{print $3}"
POSTGRES_HOST=<IP_GATEWAY_WSL>
POSTGRES_PORT=5433
POSTGRES_DB=knowledge_base
POSTGRES_USER=kb_reader
KB_READER_PASSWORD=<definir_senha>
KB_INGEST_PASSWORD=<definir_senha>
KB_ADMIN_PASSWORD=<definir_senha>
NEXUS_AGENT_PORT=8765
NEXUS_ENV=development
NEXUS_AGENT_HOST=0.0.0.0
VERIFIER_THRESHOLD=0.55
FASTEMBED_CACHE_PATH=
