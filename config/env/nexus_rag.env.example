# Obrigatorio
KB_READER_PASSWORD=senha_aqui
QDRANT_URL=http://localhost:6335

# Opcional
QDRANT_API_KEY=
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=knowledge_base
POSTGRES_USER=kb_reader
RUST_LOG=info

# "production" -> rejeita QDRANT_URL http://, ativa gate de aprovacao humana
NEXUS_ENV=development

# Deixe vazio para usar o padrao (~/.cache/fastembed_cache)
# Aponte para diretorio local em ambientes air-gapped
FASTEMBED_CACHE_PATH=

# RAG Agent / Verificador
# URL do servidor de inferencia local (Ollama).
# NAO requer servidor externo - usa Ollama local em /usr/local/bin/ollama
NEXUS_BASE_MODEL=mistral
NEXUS_OLLAMA_URL=http://localhost:11434
NEXUS_AGENT_HOST=0.0.0.0
NEXUS_AGENT_PORT=8765
VERIFIER_THRESHOLD=0.55
