+    let mut motivos: Vec<(&String, &usize)> = motivos_pending.iter().collect();
+    motivos.sort_by(|a, b| b.1.cmp(a.1));
+    for (m, n) in motivos.into_iter().take(10) {
+        println!("  {:<22} {}", m, n);
+    }
+}
