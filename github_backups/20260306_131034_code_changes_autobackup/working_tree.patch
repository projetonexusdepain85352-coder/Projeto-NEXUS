+fn recheck_codex_approved(client: &mut Client) {
+    let rows = client
+        .query(
+            "SELECT d.id::text, d.source, d.domain, d.doc_type, d.content_length,
+                    LEFT(convert_from(convert_to(d.content,'UTF8'),'UTF8'), 4000),
